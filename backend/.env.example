# Copy this file to .env and fill in your local values.
# For local dev (uvicorn directly): use localhost as the host.
# For Docker Compose: DATABASE_URL is injected by docker-compose.yml and overrides this value.

DATABASE_URL=postgresql+psycopg://<user>:<password>@localhost:5432/ai-assistant-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ai-assistant-db
